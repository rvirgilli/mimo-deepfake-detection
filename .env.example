# Local paths for mimo-deepfake-detection
# Copy to .env or export in your shell. .env itself is intentionally ignored.

# Project dependencies
ASVSPOOF_PROTOCOLS=./SSL_Anti-spoofing/database/
WAV2VEC2_XLSR_CHECKPOINT=./SSL_Anti-spoofing/xlsr2_300m.pt
MIMO_TOKENIZER_MODEL=./models/MiMo-Audio-Tokenizer

# Training/evaluation datasets
ASVSPOOF_LA_DATABASE=/path/to/ASVspoof_database/LA
ASVSPOOF_DF_DATABASE=/path/to/ASVspoof_database/DF
ASVSPOOF2021_LA_EVAL=/path/to/ASVspoof2021_LA_eval
ASVSPOOF2021_DF_EVAL=/path/to/ASVspoof2021_DF_eval
ASVSPOOF2021_LA_KEYS=/path/to/ASVspoof2021_LA_keys
ASVSPOOF_DF_KEYS=/path/to/keys/DF

# Runtime environment used by old shell scripts, if needed
CONDA_BASE=/path/to/miniconda3
CONDA_ENV=mimo-df
